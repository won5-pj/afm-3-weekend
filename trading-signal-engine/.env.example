# 이 파일을 .env 로 복사해서 값을 채우세요 (.env 는 git 에 올라가지 않음)

# --- 텔레그램 (M4에서 사용) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Supabase (M5에서 사용) ---
SUPABASE_URL=
SUPABASE_KEY=

# --- 리스크 / 포지션 사이징 ---
RISK_PCT=0.01
ACCOUNT_BALANCE=0

# --- 대상 심볼 (M1: BTC·ETH 먼저 / NDX100USDT 는 M7에서 추가) ---
SYMBOLS=BTCUSDT,ETHUSDT

# --- 캔들 마감 후 조회까지 대기 시간(초) ---
CLOSE_FETCH_DELAY_S=5
